{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],

    // "strict": true,

    "outDir": "./dist",

    "rootDir": "./src",

    "resolveJsonModule": true,

    "esModuleInterop": true,

    "skipLibCheck": true
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}